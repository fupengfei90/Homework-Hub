/* pages/detail/detail.wxss - 高端设计 */
.container {
  padding: 24rpx;
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
}

.loading {
  text-align: center;
  padding: 120rpx 0;
  color: #95a5a6;
  font-size: 28rpx;
}

.detail-container {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.detail-title {
  flex: 1;
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
  line-height: 1.5;
  margin-right: 24rpx;
  letter-spacing: -0.5rpx;
}

.detail-time {
  margin-bottom: 40rpx;
  font-size: 26rpx;
  color: #64748b;
  display: flex;
  align-items: center;
}

.detail-time::before {
  content: '🕐';
  margin-right: 8rpx;
}

.detail-content {
  margin-bottom: 48rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-radius: 20rpx;
  border-left: 4rpx solid #667eea;
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.content-label {
  font-size: 30rpx;
  color: #475569;
  font-weight: 600;
}

/* 小朗读按钮 */
.read-aloud-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
  transition: all 0.3s;
}

.read-aloud-btn.reading {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  box-shadow: 0 4rpx 12rpx rgba(239, 68, 68, 0.3);
  animation: pulse 1.5s infinite;
}

.read-aloud-btn:active {
  transform: scale(0.95);
}

.read-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.read-text {
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 500;
}

.content-text {
  font-size: 32rpx;
  color: #334155;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

.media-section {
  margin-bottom: 48rpx;
}

.media-label {
  font-size: 30rpx;
  color: #475569;
  margin-bottom: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
}

.label-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 链接卡片 */
.link-card {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 2rpx solid #e2e8f0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.link-info {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #ffffff;
  border-radius: 12rpx;
  border: 1rpx solid #e2e8f0;
}

.link-url {
  font-size: 26rpx;
  color: #475569;
  word-break: break-all;
  line-height: 1.6;
}

.link-actions {
  display: flex;
  justify-content: flex-end;
}

.copy-link-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s;
}

.copy-link-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.copy-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.media-container {
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.video-player {
  width: 100%;
  height: 420rpx;
  background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
}

.audio-player {
  width: 100%;
  background: #ffffff;
  border-radius: 20rpx;
}

.media-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #e2e8f0 100%);
  border-radius: 20rpx;
  border: 2rpx dashed #cbd5e0;
}

.media-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.1));
}

.play-btn {
  padding: 24rpx 48rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s;
}

.play-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.error-text {
  color: #ff6b6b;
  font-size: 28rpx;
  font-weight: 500;
}

/* 提醒设置区域 */
.reminder-section {
  margin-top: 48rpx;
  padding-top: 32rpx;
  border-top: 2rpx solid #f1f5f9;
}

.reminder-btn {
  width: 100%;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.reminder-btn:active {
  transform: translateY(2rpx);
  box-shadow: 0 4rpx 16rpx rgba(245, 158, 11, 0.4);
}

.reminder-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* ========== 大朗读按钮区域（方便小朋友点击） ========== */
.big-read-section {
  margin-bottom: 48rpx;
  padding: 0 8rpx;
}

/* 朗读模式切换 */
.read-mode-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 20rpx;
  border: 2rpx solid #bae6fd;
}

.mode-label {
  font-size: 28rpx;
  color: #0284c7;
  font-weight: 600;
}

.mode-buttons {
  display: flex;
  gap: 16rpx;
}

.mode-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 2rpx solid #bae6fd;
  transition: all 0.3s;
  min-width: 120rpx;
}

.mode-btn.active {
  background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
  border-color: #0284c7;
  box-shadow: 0 4rpx 12rpx rgba(2, 132, 199, 0.3);
}

.mode-btn text:nth-child(1) {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.mode-btn text:nth-child(2) {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

.mode-btn.active text:nth-child(2) {
  color: #ffffff;
}

.mode-btn:active {
  transform: scale(0.95);
}

/* 目标语言选择 */
.target-lang-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  border-radius: 20rpx;
  border: 2rpx solid #fcd34d;
}

.lang-label {
  font-size: 28rpx;
  color: #d97706;
  font-weight: 600;
}

.lang-buttons {
  display: flex;
  gap: 16rpx;
}

.lang-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 2rpx solid #fcd34d;
  transition: all 0.3s;
  min-width: 120rpx;
}

.lang-btn.active {
  background: linear-gradient(135deg, #d97706 0%, #b45309 100%);
  border-color: #d97706;
  box-shadow: 0 4rpx 12rpx rgba(217, 119, 6, 0.3);
}

.lang-btn text:nth-child(1) {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.lang-btn text:nth-child(2) {
  font-size: 24rpx;
  color: #475569;
  font-weight: 500;
}

.lang-btn.active text:nth-child(2) {
  color: #ffffff;
}

.lang-btn:active {
  transform: scale(0.95);
}

.big-read-btn {
  width: 100%;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 32rpx;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(16, 185, 129, 0.4);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
}

.big-read-btn.reading {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  box-shadow: 0 12rpx 32rpx rgba(239, 68, 68, 0.4);
  animation: pulse 1.5s infinite;
}

.big-read-btn:active {
  transform: scale(0.97);
  box-shadow: 0 6rpx 20rpx rgba(16, 185, 129, 0.4);
}

.big-read-btn.reading:active {
  box-shadow: 0 6rpx 20rpx rgba(239, 68, 68, 0.4);
}

.big-read-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0, 0, 0, 0.2));
}

.big-read-title {
  font-size: 40rpx;
  color: #ffffff;
  font-weight: 700;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

.big-read-hint {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 400;
}

/* 脉冲动画 */
@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.02);
  }
  100% {
    transform: scale(1);
  }
}
